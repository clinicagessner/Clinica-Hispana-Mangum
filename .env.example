# ─────────────────────────────────────────────────────────────
# Clínica Hispana Mangum — variables de entorno
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA subas .env.local al repositorio.
# ─────────────────────────────────────────────────────────────

# Resend (email transaccional del formulario de contacto)
RESEND_API_KEY=
RESEND_FROM=

# Meta Pixel + Conversions API (tracking de leads)
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# URL pública del sitio (sin slash final)
NEXT_PUBLIC_SITE_URL=https://www.clinicahispanamangum.com

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Google Ads (formato AW-XXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Places API (New) — server-side, alimenta rating/reseñas en vivo del JSON-LD
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=ChIJiwK3lynHQIYRwtpk4wSI-lM

# IndexNow (ping a buscadores; el archivo de clave se sirve desde /public/<key>.txt)
INDEXNOW_KEY=
